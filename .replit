modules = ["java-graalvm22.3", "python-3.11", "nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["jdk21"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Build Mod"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Dev History Dashboard"

[[workflows.workflow]]
name = "Build Mod"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "export JAVA_HOME=$(dirname $(dirname $(which java))) && ./gradlew build --no-daemon"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Dev History Dashboard"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/dev-history-dashboard && PORT=5000 BASE_PATH='/' npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
isCanvasWorkflow = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[deployment]
deploymentTarget = "static"
publicDir = "public"

[[ports]]
localPort = 5000
externalPort = 80
